{
  "name": "skylit-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "npm-run-all -p dev:frontend dev:backend",
    "dev": "npm-run-all -p dev:frontend dev:backend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "ts-node-dev --respawn --transpile-only --project backend/tsconfig.json backend/server.ts",
    "setup:db": "node check-database.js"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@types/redis": "^4.0.10",
    "redis": "^5.8.2"
  }
}
