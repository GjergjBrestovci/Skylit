{
  "css.validate": false,
  "postcss.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "files.associations": {
    "*.css": "postcss"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.includeLanguages": {
    "postcss": "postcss"
  },
  "tailwindCSS.experimental.classRegex": [
    ["class:\\s*?[\"'`]([^\"'`]*).*?[\"'`]", "[\"'`]([^\"'`]*)[\"'`]"]
  ],
  "emmet.includeLanguages": {
    "postcss": "css"
  }
}
