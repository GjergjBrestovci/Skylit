# Production Environment Variables for Railway
# Set these in your Railway project settings

# Server Configuration
NODE_ENV=production
PORT=3001

# Domain Configuration
FRONTEND_URL=https://skylit.vercel.app
API_URL=https://skylit-api.railway.app

# Database (Supabase) - Replace with your actual values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Authentication - Generate secure secrets
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_minimum_32_characters

# AI Services - Configure your preferred provider
OPENROUTER_API_KEY=your_openrouter_api_key
# OR
# OPENAI_API_KEY=your_openai_api_key

# Cache (Upstash Redis) - Replace with your Redis URL
REDIS_URL=rediss://default:password@host:port

# Payments (Stripe) - Replace with your Stripe keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_BASIC_PRICE_ID=price_your_basic_price
STRIPE_PRO_PRICE_ID=price_your_pro_price
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price

# Security
CORS_ORIGIN=https://skylit.vercel.app,https://www.skylit.ai
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Monitoring - Optional, configure if you want monitoring
SENTRY_DSN=your_sentry_dsn

# Features
MOCK_AI=false
AUTH_BYPASS=false
STRIPE_ENABLED=true
