# Backend server
PORT=5000

# Database connection

SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# JWT Secret (change in production)
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Development: Set a real Supabase user UUID to persist projects in dev mode
# Without this, projects are captured but not saved to DB when using dev bypass
# DEV_SUPABASE_USER_ID=your-supabase-user-uuid

# AI key (placeholder - do NOT use real key here)
AI_API_KEY=YOUR_AI_KEY_HERE

# Future: additional provider keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
